# Finance Signal Studio - environment variables
# Copy this file to .env.local and fill in the values you want to enable.

# Market data (Alpha Vantage)
# Free tier: 25 API requests / day. The app makes ~5 per page load.
ALPHA_VANTAGE_API_KEY=

# News
NEWS_API_KEY=

# AI engines
GEMINI_API_KEY=
GROQ_API_KEY=

# Social signals via Apify (optional)
APIFY_API_TOKEN=
X_SEARCH_ACTOR_ID=
INSTAGRAM_SEARCH_ACTOR_ID=
FACEBOOK_SEARCH_ACTOR_ID=

# Supabase persistence (optional)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
